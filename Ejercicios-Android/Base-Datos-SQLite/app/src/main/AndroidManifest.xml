<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="dm2e.jesus.basedatos">

    <application
        android:allowBackup="true"
        android:label="BaseDatosApp"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BaseDatos">

        <!-- Actividad principal -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Declarar todas las actividades -->
        <activity android:name=".InsertarActivity" />
        <activity android:name=".ModificarActivity" />
        <activity android:name=".BorrarActivity" />
        <activity android:name=".RegistrosActivity" />
        <activity android:name=".RegistroUnicoActivity" />

    </application>

</manifest>
